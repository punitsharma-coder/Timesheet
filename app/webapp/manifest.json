{
    "_version": "1.58.0",
    "sap.app": {
        "id":          "timesheet.app",
        "type":        "application",
        "title":       "Timesheet",
        "description": "Weekly Timesheet Dashboard",
        "dataSources": {
            "TimesheetService": {
                "uri":  "/timesheet/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui": {
        "technology":  "UI5",
        "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "timesheet.app.view.App",
            "type":     "XML",
            "id":       "AppView"
        },
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.ui.core":    {},
                "sap.m":          {},
                "sap.f":          {},
                "sap.ui.layout":  {},
                "sap.ui.table":   {},
                "sap.uxap":       {}
            }
        },
        "models": {
            "": {
                "dataSource":           "TimesheetService",
                "preload":              true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "view": {
                "type":             "sap.ui.model.json.JSONModel",
                "settings": { "data": {} }
            },
            "i18n": {
                "type":             "sap.ui.model.resource.ResourceModel",
                "settings": { "bundleName": "timesheet.app.i18n.i18n" }
            }
        },
        "routing": {
            "config": {
                "routerClass":  "sap.m.routing.Router",
                "viewType":     "XML",
                "viewPath":     "timesheet.app.view",
                "controlAggregation": "pages",
                "controlId":    "app",
                "transition":   "slide"
            },
            "routes": [
                {
                    "name":    "dashboard",
                    "pattern": "",
                    "target":  "dashboard"
                }
            ],
            "targets": {
                "dashboard": {
                    "viewName": "Dashboard",
                    "viewId":   "dashboard"
                }
            }
        }
    }
}
