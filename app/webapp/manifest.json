{
    "_version": "1.58.0",
    "sap.app": {
        "id":          "timesheet.app",
        "type":        "application",
        "title":       "Timesheet",
        "description": "Weekly Timesheet Dashboard",
        "dataSources": {
            "TimesheetService": {
                "uri":  "/employee/",
                "type": "OData",
                "settings": { "odataVersion": "4.0" }
            }
        }
    },
    "sap.ui": {
        "technology":  "UI5",
        "deviceTypes": { "desktop": true, "tablet": true, "phone": false }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "timesheet.app.view.App",
            "type":     "XML",
            "id":       "AppView"
        },
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.ui.core":    {},
                "sap.m":          {},
                "sap.f":          {},
                "sap.ui.layout":  {},
                "sap.ui.table":   {},
                "sap.ui.unified": {},
                "sap.uxap":       {}
            }
        },
        "models": {
            "": {
                "dataSource":  "TimesheetService",
                "preload":     true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode":       "Server",
                    "autoExpandSelect":    true
                }
            },
            "view": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": {} }
            },
            "rows": {
                "type":    "sap.ui.model.json.JSONModel",
                "settings": { "data": { "rows": [] } }
            },
            "i18n": {
                "type":    "sap.ui.model.resource.ResourceModel",
                "settings": { "bundleName": "timesheet.app.i18n.i18n" }
            }
        },
        "routing": {
            "config": {
                "routerClass":        "sap.m.routing.Router",
                "viewType":           "XML",
                "viewPath":           "timesheet.app.view",
                "controlAggregation": "pages",
                "controlId":          "detailNav",
                "transition":         "slide"
            },
            "routes": [
                { "name": "dashboard",     "pattern": "",              "target": "dashboard"     },
                { "name": "history",       "pattern": "history",       "target": "history"       },
                { "name": "manager",       "pattern": "manager",       "target": "manager"       },
                { "name": "notifications", "pattern": "notifications", "target": "notifications" }
            ],
            "targets": {
                "dashboard":     { "viewName": "Dashboard",     "viewId": "dashboard"     },
                "history":       { "viewName": "History",       "viewId": "history"       },
                "manager":       { "viewName": "Manager",       "viewId": "manager"       },
                "notifications": { "viewName": "Notifications", "viewId": "notifications" }
            }
        }
    }
}
