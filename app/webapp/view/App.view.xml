<mvc:View
    controllerName="timesheet.app.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:ShellBar
        id="shellBar"
        title="TIMESHEET"
        showMenuButton="true"
        menuButtonPress=".onMenuToggle"
        showNotifications="true"
        showProductSwitcher="false">
        <f:profile>
            <Avatar initials="JD" displaySize="XS" press=".onProfilePress" />
        </f:profile>
    </f:ShellBar>

    <SplitApp id="app">

        <masterPages>
            <Page id="navPage" showHeader="false" class="timesheetSidebar">

                <List id="mainNavList" selectionChange=".onNavSelect" mode="SingleSelectMaster">
                    <items>
                        <StandardListItem title="Dashboard" icon="sap-icon://home" type="Active">
                            <customData><core:CustomData key="target" value="dashboard" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet" icon="sap-icon://calendar" type="Active">
                            <customData><core:CustomData key="target" value="dashboard" /></customData>
                        </StandardListItem>
                        <StandardListItem title="My Wallet" icon="sap-icon://wallet" type="Active">
                            <customData><core:CustomData key="target" value="dashboard" /></customData>
                        </StandardListItem>
                        <StandardListItem title="Timesheet History" icon="sap-icon://history" type="Active">
                            <customData><core:CustomData key="target" value="history" /></customData>
                        </StandardListItem>
                    </items>
                </List>

                <List id="accountNavList" headerText="Account" mode="None">
                    <items>
                        <StandardListItem title="Notifications" icon="sap-icon://bell" />
                        <StandardListItem title="Settings"      icon="sap-icon://action-settings" />
                        <StandardListItem title="FAQ"           icon="sap-icon://sys-help" />
                    </items>
                </List>

                <footer>
                    <OverflowToolbar class="tsSidebarFooter">
                        <Button text="Log Out" icon="sap-icon://log" type="Negative" press=".onLogout" />
                    </OverflowToolbar>
                </footer>

            </Page>
        </masterPages>

        <!-- Router renders dashboard/history views into this NavContainer -->
        <detailPages>
            <NavContainer id="detailNav" />
        </detailPages>

    </SplitApp>

</mvc:View>