<mvc:View
    controllerName="timesheet.app.controller.Notifications"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="notificationsPage" class="tsDashboardPage" showNavButton="false" enableScrolling="true">

        <customHeader>
            <Bar class="tsPageHeader">
                <contentLeft>
                    <VBox>
                        <Title text="Notifications" level="H2" />
                        <Text text="{= ${notifView>/unreadCount} > 0 ? ${notifView>/unreadCount} + ' unread' : 'All caught up' }"
                            class="tsNotifSubtitle" />
                    </VBox>
                </contentLeft>
                <contentRight>
                    <Button text="Mark All as Read" type="Transparent" icon="sap-icon://accept"
                        visible="{= ${notifView>/unreadCount} > 0 }"
                        press=".onMarkAllRead" />
                </contentRight>
            </Bar>
        </customHeader>

        <content>

            <!-- Empty state -->
            <VBox visible="{= !${notifView>/hasNotifications} }" class="tsNotifEmpty">
                <core:Icon src="sap-icon://bell" size="3rem" color="#d1d5db"
                    class="sapUiSmallMarginBottom" />
                <Title text="No Notifications" level="H4" class="sapUiTinyMarginBottom" />
                <Text text="You'll be notified here when your manager approves or rejects a timesheet."
                    textAlign="Center" class="tsNotifEmptyHint" />
            </VBox>

            <!-- Notification cards -->
            <List visible="{notifView>/hasNotifications}"
                  items="{notifView>/notifications}"
                  mode="None"
                  showSeparators="Inner"
                  itemPress=".onNotifPress"
                  class="tsNotifList">

                <CustomListItem type="Navigation" class="tsNotifItem">

                    <HBox alignItems="Center" class="tsNotifCard">

                        <!-- Status icon -->
                        <VBox class="tsNotifIconWrap" alignItems="Center" justifyContent="Center">
                            <core:Icon
                                src="{path:'notifView>type', formatter:'.formatTypeIcon'}"
                                color="{path:'notifView>type', formatter:'.formatTypeColor'}"
                                size="1.4rem" />
                        </VBox>

                        <!-- Message content -->
                        <VBox class="tsNotifBody">
                            <HBox alignItems="Center" justifyContent="SpaceBetween">
                                <ObjectStatus
                                    text="{path:'notifView>type', formatter:'.formatTypeLabel'}"
                                    state="{path:'notifView>type', formatter:'.formatTypeState'}"
                                    class="tsNotifBadge" />
                                <Text text="{path:'notifView>timestamp', formatter:'.formatTimestamp'}"
                                    class="tsNotifTime" />
                            </HBox>
                            <Text text="{notifView>message}" class="tsNotifMessage" wrapping="true" />
                        </VBox>

                        <!-- Unread dot -->
                        <VBox class="tsNotifDotWrap" alignItems="Center" justifyContent="Center">
                            <core:Icon src="sap-icon://circle-task-2"
                                visible="{= !${notifView>read} }"
                                color="#3b82f6" size="0.6rem" class="tsNotifUnreadDot" />
                        </VBox>

                    </HBox>

                </CustomListItem>

            </List>

        </content>

    </Page>

</mvc:View>
