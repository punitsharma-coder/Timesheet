<mvc:View
    controllerName="timesheet.app.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fcard="sap.f.cards"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="dashPage" class="tsDashPage" showHeader="false" enableScrolling="true">
        <content>
            <VBox class="tsDashOuter">

                <!-- ── Greeting ── -->
                <HBox justifyContent="SpaceBetween" alignItems="Center" class="tsDashGreetingRow">
                    <VBox>
                        <Title text="{dash>/greeting}" level="H4" class="sapUiTinyMarginBegin sapUiTinyMarginTop sapUiTinyMarginBottom" />
                        <Text text="Here's your timesheet activity" class="sapUiSmallMarginBegin sapUiTinyMarginTop sapUiSmallMarginBottom" />
                    </VBox>
                    <Text text="{dash>/todayLabel}" class="tsDashDateLabel" />
                </HBox>

                <!-- ── Week Navigator ── -->
                <Toolbar class="tsDashWeekBar" style="Clear">
                    <Title text="{dash>/weekLabel}" level="H5" class="tsDashWeekTitle" />
                    <ToolbarSpacer />
                    <Button icon="sap-icon://navigation-left-arrow" type="Transparent" press=".onPrevWeek" />
                    <Button text="Today" type="Transparent" press=".onToday" />
                    <Button icon="sap-icon://navigation-right-arrow" type="Transparent" press=".onNextWeek" enabled="{= !${dash>/isNextDisabled} }"/>
                </Toolbar>

                <!-- ── Full dashboard grid rendered by controller ── -->
                <core:HTML id="dashGrid" sanitizeContent="false" content="{dash>/dashGridHTML}" />

            </VBox>
        </content>
    </Page>

</mvc:View>