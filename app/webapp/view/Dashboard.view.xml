<mvc:View
    controllerName="timesheet.app.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="dashboardPage"
        showHeader="false"
        class="sapUiContentPadding">

        <!-- ── Page Header ── -->
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="Timesheet" level="H2" />
                </contentLeft>
                <contentRight>
                    <!-- Day / Week toggle -->
                    <SegmentedButton
                        id="viewToggle"
                        selectedKey="week"
                        selectionChange=".onViewToggle">
                        <items>
                            <SegmentedButtonItem key="day"  text="Day"  />
                            <SegmentedButtonItem key="week" text="Week" />
                        </items>
                    </SegmentedButton>

                    <Button
                        text="Add Row"
                        icon="sap-icon://add"
                        type="Emphasized"
                        press=".onAddRow" />
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <!-- Breadcrumb -->
            <Breadcrumbs class="sapUiSmallMarginBottom">
                <links>
                    <Link text="Dashboard" />
                </links>
                <currentLocationText>Timesheet</currentLocationText>
            </Breadcrumbs>

            <!-- ── Week Navigator ── -->
            <Toolbar class="sapUiSmallMarginBottom" style="background:transparent;padding:0">
                <Title
                    id="weekRangeTitle"
                    text="{view>/weekRangeLabel}"
                    level="H4" />
                <ToolbarSpacer />
                <core:Icon src="sap-icon://calendar" class="sapUiSmallMarginEnd" />
                <Button
                    icon="sap-icon://navigation-left-arrow"
                    type="Transparent"
                    press=".onPrevWeek" />
                <Button
                    text="Today"
                    type="Transparent"
                    press=".onToday" />
                <Button
                    icon="sap-icon://navigation-right-arrow"
                    type="Transparent"
                    press=".onNextWeek" />
            </Toolbar>

            <!-- ── Timesheet Grid ── -->
            <table:Table
                id="timesheetTable"
                rows="{
                    path: '/TimeEntries',
                    parameters: {
                        expand: 'project',
                        $filter: 'weekStart eq {view>/weekStartFilter}'
                    }
                }"
                visibleRowCountMode="Auto"
                minAutoRowCount="3"
                selectionMode="None"
                alternateRowColors="true"
                fixedColumnCount="1"
                class="timesheetTable">

                <table:extension>
                    <!-- Column totals header row -->
                    <Toolbar style="background:var(--sapList_HeaderBackground)">
                        <Text text="" width="200px" />
                        <Text text="{view>/days/0/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/1/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/2/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/3/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/4/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/5/label}" width="90px" textAlign="Center" />
                        <Text text="{view>/days/6/label}" width="90px" textAlign="Center" />
                        <Text text="Total" width="80px" textAlign="Center" class="sapUiSmallMarginBegin" />
                    </Toolbar>
                </table:extension>

                <table:columns>
                    <!-- Project / Task column -->
                    <table:Column width="200px" label="Project">
                        <table:template>
                            <VBox>
                                <Text text="{project/name}" class="sapUiTinyMarginBottom" />
                                <Text text="{taskName}" class="sapUiSmallFontSize" />
                            </VBox>
                        </table:template>
                    </table:Column>

                    <!-- Mon -->
                    <table:Column width="90px" hAlign="Center" label="Mon">
                        <table:template>
                            <Input
                                value="{
                                    path: 'mon',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="mon" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Tue -->
                    <table:Column width="90px" hAlign="Center" label="Tue">
                        <table:template>
                            <Input
                                value="{
                                    path: 'tue',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="tue" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Wed -->
                    <table:Column width="90px" hAlign="Center" label="Wed">
                        <table:template>
                            <Input
                                value="{
                                    path: 'wed',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="wed" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Thu -->
                    <table:Column width="90px" hAlign="Center" label="Thu">
                        <table:template>
                            <Input
                                value="{
                                    path: 'thu',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="thu" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Fri -->
                    <table:Column width="90px" hAlign="Center" label="Fri">
                        <table:template>
                            <Input
                                value="{
                                    path: 'fri',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="fri" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Sat -->
                    <table:Column width="90px" hAlign="Center" label="Sat">
                        <table:template>
                            <Input
                                value="{
                                    path: 'sat',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="sat" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Sun -->
                    <table:Column width="90px" hAlign="Center" label="Sun">
                        <table:template>
                            <Input
                                value="{
                                    path: 'sun',
                                    type: 'sap.ui.model.type.Float',
                                    formatOptions: { maxFractionDigits: 2 }
                                }"
                                width="70px"
                                textAlign="Center"
                                change=".onHoursChange"
                                class="timesheetInput"
                                customData>
                                <customData>
                                    <core:CustomData key="day" value="sun" />
                                </customData>
                            </Input>
                        </table:template>
                    </table:Column>

                    <!-- Row Total (computed) -->
                    <table:Column width="80px" hAlign="Center" label="Total">
                        <table:template>
                            <Text
                                text="{
                                    parts: ['mon','tue','wed','thu','fri','sat','sun'],
                                    formatter: '.formatRowTotal'
                                }"
                                class="sapUiSmallMarginBegin" />
                        </table:template>
                    </table:Column>
                </table:columns>
            </table:Table>

            <!-- ── Grand Total ── -->
            <Toolbar class="sapUiMediumMarginTop" style="background:transparent;justify-content:flex-end">
                <Text text="Total : " class="sapUiSmallMarginEnd" />
                <Title text="{view>/grandTotal}" level="H4" />
            </Toolbar>

        </content>
    </Page>

</mvc:View>
