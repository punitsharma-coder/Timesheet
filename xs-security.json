{
  "xsappname": "timesheet-app",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Employee",
      "description": "Employee role"
    },
    {
      "name": "$XSAPPNAME.Manager",
      "description": "Manager role"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "Employee",
      "description": "Employee Role",
      "scope-references": [
        "$XSAPPNAME.Employee"
      ]
    },
    {
      "name": "Manager",
      "description": "Manager Role template",
      "scope-references": [
        "$XSAPPNAME.Employee",
        "$XSAPPNAME.Manager"
      ]
    }
  ],
   "role-collections": [
        {
            "name": "Timesheet_Employee",
            "description": "Timesheet Employee",
            "role-template-references": [
                "$XSAPPNAME.Employee"
            ]
        },
        {
            "name": "Timesheet_Manager",
            "description": "Timesheet Manager",
            "role-template-references": [
                "$XSAPPNAME.Manager"
            ]
        }
    ],
  "oauth2-configuration":{
    "token-validity" : 900,
    "redirect-uris": [
    "https://*.cfapps.us10-001.hana.ondemand.com/**"
    ]
  },
  "xsenableasyncservice": "true"
}